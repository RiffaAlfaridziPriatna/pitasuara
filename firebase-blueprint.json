{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "rank": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "xp", "level"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "A speech exercise for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "baseXP": { "type": "integer" }
      },
      "required": ["id", "text", "category", "difficulty", "baseXP"]
    },
    "Result": {
      "title": "Result",
      "description": "Recording analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "exerciseId": { "type": "string" },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "clarityScore": { "type": "number" },
        "intonationScore": { "type": "number" },
        "xpEarned": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "exerciseId", "score", "feedback", "xpEarned", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and stats"
    },
    "exercises/{exerciseId}": {
      "schema": "Exercise",
      "description": "Available speech exercises"
    },
    "results/{resultId}": {
      "schema": "Result",
      "description": "Historial exercise results"
    }
  }
}
